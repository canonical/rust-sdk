{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^VERSION$/"],
      "matchStrings": [
        "(?<currentValue>[0-9.]+)"
      ],
      "depNameTemplate": "rust-lang/rustup",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ],
  "baseBranchPatterns": [
    "1"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["rust-lang/rustup"],
      "matchBaseBranches": ["1"],
      "allowedVersions": "/^1\\./"
    }
  ]
}
